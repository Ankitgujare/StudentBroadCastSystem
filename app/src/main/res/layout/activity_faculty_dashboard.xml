<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Faculty Dashboard"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnLogoutFaculty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:layout_marginBottom="16dp"
        android:textColor="@android:color/white"
        android:backgroundTint="@android:color/holo_red_dark" />

    <Button
        android:id="@+id/btnViewMyRequests"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View My Requests"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@android:color/holo_blue_dark"
        android:textColor="@android:color/white" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Branch(es):" />

    <TextView
        android:id="@+id/tvSelectedBranches"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to select branches"
        android:padding="12dp"
        android:background="#EEEEEE"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Semester(s):" />

    <TextView
        android:id="@+id/tvSelectedSemesters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to select semesters"
        android:padding="12dp"
        android:background="#EEEEEE"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <CheckBox
        android:id="@+id/cbIndividual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Send to Individual Student"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etIndividualEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Student Email Address"
        android:inputType="textEmailAddress"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etSubject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Subject"
        android:inputType="text"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/messageBox"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:gravity="top|start"
        android:hint="Write your message here..."
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/sendButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send for Approval" />

    </LinearLayout>
</ScrollView>